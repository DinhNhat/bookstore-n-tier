@model ServiceLayer.AdminServices.ChangePubDateDto

@{
    ViewData["Title"] = "Change Published Date";
}

<h3>Change Publication Date</h3>
<form asp-controller="Admin" asp-action="ChangePubDate" method="post">
    <!-- Input and Submit elements -->
    <input name="BookId" type="hidden" value="@Model.BookId"/>

    <div class="form-group">
        <div class="col-md-6">
            <label>Book Title:</label> <span class="font-weight-bold">@Model.Title</span>
        </div>
    </div>

    <div class="form-group">
        <label>Publication Date</label>
        <input asp-for="PublishedOn" class="form-control col-sm-3"/>
    </div>

    <div class="form-group mt-2">
        <div class="col-md-10">
            <button class="btn btn-primary" type="submit">Update</button>
        </div>
    </div>

</form>